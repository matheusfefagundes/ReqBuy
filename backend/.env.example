# Banco de dados
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reqbuy

# JWT
JWT_SECRET=gere_um_segredo_aleatorio_com_mais_de_32_caracteres

# Ambiente (muda comportamento do cookie Secure)
NODE_ENV=development

# Salt para pseudonimização de IPs (LGPD)
IP_HASH_SALT=gere_outro_valor_aleatorio_diferente_do_jwt_secret

# Dias de retenção dos logs de auditoria (padrão: 90)
AUDIT_RETENTION_DAYS=90

# URL do frontend (CORS)
FRONTEND_URL=http://localhost:5173

# Porta do backend
PORT=3001
